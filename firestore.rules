rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 개인 캐릭터 (5슬롯) ──
    match /users/{userId}/characters/{slotId} {
      // 본인은 항상 읽기/쓰기 가능
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // GM이 세션 참가자의 캐릭터를 편집할 수 있도록
      // (캐릭터 doc에 sessionId가 있으면 해당 세션의 GM에게 허용)
      allow read, write: if request.auth != null
        && resource.data.sessionId != null
        && get(/databases/$(database)/documents/sessions/$(resource.data.sessionId)).data.gmUid == request.auth.uid;
    }

    // ── 세션 ──
    match /sessions/{sessionId} {
      // 누구나 읽기 가능 (참가 코드 검증용)
      allow read: if request.auth != null;
      // GM만 생성
      allow create: if request.auth != null;
      // GM 또는 세션 참가자가 수정 (플레이어 참가/퇴장)
      allow update: if request.auth != null
        && (resource.data.gmUid == request.auth.uid
            || resource.data.players[request.auth.uid] != null);
      // GM만 삭제
      allow delete: if request.auth != null
        && resource.data.gmUid == request.auth.uid;

      // ── 주사위 굴림 ──
      match /rolls/{rollId} {
        // 세션 참가자면 읽기 가능
        allow read: if request.auth != null;
        // 로그인한 사용자가 자기 uid로만 생성 가능
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        // GM만 삭제 (정리용)
        allow delete: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.gmUid;
      }
    }
  }
}
